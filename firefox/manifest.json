{
  "manifest_version": 3,
  "name": "PR File Zipper",
  "version": "1.0.0",
  "description": "Download all changed files in a GitHub Pull Request as a ZIP with folder structure preserved.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/pull/*"
      ],
      "js": ["browser-polyfill.js", "jszip.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PR File Zipper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pr-file-zipper@przipper",
      "strict_min_version": "109.0"
    }
  }
}
